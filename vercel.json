{
    "version": 2,
    "buildCommand": "npm install && npm run build",
    "outputDirectory": "public",
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "@vercel/php"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|fonts|build)/(.+)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "Dahab Tech",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://dahab-tech.vercel.app",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "QUEUE_CONNECTION": "sync"
    }
}
